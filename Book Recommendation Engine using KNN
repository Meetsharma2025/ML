ratings = ratings.merge(books, on='ISBN')

user_counts = ratings['User-ID'].value_counts()
ratings = ratings[ratings['User-ID'].isin(user_counts[user_counts >= 200].index)]

book_counts = ratings['Book-Title'].value_counts()
ratings = ratings[ratings['Book-Title'].isin(book_counts[book_counts >= 100].index)]

book_pivot = ratings.pivot_table(
    index='Book-Title',
    columns='User-ID',
    values='Book-Rating'
).fillna(0)

from scipy.sparse import csr_matrix
book_sparse = csr_matrix(book_pivot.values)

from sklearn.neighbors import NearestNeighbors

model = NearestNeighbors(metric='cosine', algorithm='brute')
model.fit(book_sparse)

def get_recommends(book=""):

    distances, indices = model.kneighbors(
        book_pivot.loc[book].values.reshape(1, -1),
        n_neighbors=6
    )

    rec_books = []

    for i in range(1, len(distances.flatten())):
        rec_books.append([
            book_pivot.index[indices.flatten()[i]],
            distances.flatten()[i]
        ])

    return [book, rec_books]
